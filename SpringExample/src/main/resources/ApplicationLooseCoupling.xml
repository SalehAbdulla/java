<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <!-- implements UserDataProvider -->

    <bean id="mongoPro" class="com.loose.coupling.MongoDBProvider"/>
    <bean id="webPro" class="com.loose.coupling.WebServiceDataProvider"/>
    <bean id="userDbPro" class="com.loose.coupling.UserDatabaseProvider"/>

    <bean id="userDbProManager" class="com.loose.coupling.UserManager">
        <constructor-arg ref="userDbPro"/>
    </bean>

    <bean id="webProManager" class="com.loose.coupling.UserManager">
        <constructor-arg ref="webPro"/>
    </bean>

    <bean id="mongoProManager" class="com.loose.coupling.UserManager">
        <constructor-arg ref="mongoPro"/>
    </bean>

</beans>