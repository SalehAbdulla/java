<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="myCarSetter" class="car.example.setter.injection.Car" >
        <property name="specification" ref="specificationSetter"/>
    </bean>

    <bean id="specificationSetter" class="car.example.setter.injection.Specification">
        <property name="model" value="LUXES"/>
        <property name="make" value="-LS"/>
    </bean>

</beans>